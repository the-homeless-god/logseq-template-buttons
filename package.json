{
  "name": "logseq-template-buttons",
  "version": "0.1.1",
  "description": "Custom sidebar buttons to create pages from Logseq templates",
  "main": "dist/index.html",
  "targets": {
    "main": false
  },
  "scripts": {
    "build": "parcel build --no-source-maps index.html --public-url ./",
    "dev": "parcel build --no-optimize index.html --public-url ./",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "logseq",
    "template",
    "plugin"
  ],
  "author": "Marat Zimnurov",
  "license": "BSD-3-Clause",
  "dependencies": {
    "@logseq/libs": "^0.0.17",
    "logseq-dateutils": "^0.0.21"
  },
  "logseq": {
    "id": "logseq-template-buttons",
    "title": "Template Buttons",
    "icon": "./icon.png",
    "description": "Sidebar buttons to create new pages from templates.",
    "author": "Marat Zimnurov",
    "repo": "the-homeless-god/logseq-template-buttons",
    "theme": false,
    "sponsors": [],
    "web": false,
    "effect": true,
    "supportsDB": false,
    "supportsDBOnly": false
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "parcel": "^2.0.0",
    "typescript": "^4.8.3",
    "vitest": "^4.1.7"
  }
}
